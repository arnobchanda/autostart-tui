[Desktop Entry]
Type=Application
Version=1.0
Name=Autostart Manager
GenericName=Startup & Launcher Apps
Comment=Enable or disable XDG autostart entries and launcher visibility
Exec=ghostty --gtk-single-instance=false --class=autostart-tui --title=autostart-tui -e autostart-tui
Icon=system-run
Terminal=false
Categories=System;Settings;
Keywords=autostart;startup;boot;login;session;launcher;walker;xdg
